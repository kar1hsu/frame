# 全局时区，统一日志 / JWT / 数据库 / 定时任务等所有带时区的地方（IANA 名，如 Asia/Shanghai、UTC）
# docker 部署时可由 compose 的 TIMEZONE 环境变量覆盖
timezone: Asia/Shanghai

server:
  port: 8080
  mode: debug # debug | release | test
  # 允许的跨域来源；留空或不配置则回退为 "*"。生产环境建议配置显式白名单：
  # allow_origins:
  #   - https://admin.example.com

database:
  driver: mysql # mysql | postgres
  host: 127.0.0.1
  port: 3306
  username: root
  password: root
  dbname: frame
  charset: utf8mb4
  max_idle_conns: 10
  max_open_conns: 100
  log_level: info # silent | error | warn | info

redis:
  host: 127.0.0.1
  port: 6379
  password: ""
  db: 0
  key_prefix: "frame:"   # Redis key 全局前缀，避免多项目 key 冲突

jwt:
  secret: frame-jwt-secret-key-change-in-production
  expire: 7200    # token 过期时间（秒）
  issuer: frame

casbin:
  model_path: config/rbac_model.conf

task:
  concurrency: 10                  # Worker 并发数
  queues:                          # 队列列表（按优先级从高到低）
    - critical
    - default
    - low

log:
  level: info       # debug | info | warn | error
  format: console   # console | json
  directory: logs
  max_size: 100     # MB
  max_backups: 10
  max_age: 30       # days
